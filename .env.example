# Copy this file to .env and fill in your keys.
# All keys are optional — the pipeline gracefully degrades to mock/stub providers
# for any missing key.

# LLM providers (at least one recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Transcription (optional — falls back to stub if not set)
# Used for translate-audio command
# OPENAI_API_KEY is also used for Whisper transcription

# Audio isolation (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google (optional — for GoogleSpeechProvider, currently stub)
GOOGLE_API_KEY=your_google_api_key_here

# Lyrics (optional — falls back to mock if not set)
# GENIUS_ACCESS_TOKEN=your_genius_access_token_here
